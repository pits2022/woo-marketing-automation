; WordPress
WP_LOAD_PATH=/var/www/html/wp-load.php

; Sendy
SENDY_DIR=/var/www/html/sendy
SENDY_URL=https://sendy.webshop.hu
SENDY_LIST=your_default_list_id
SENDY_RAFFLE_LIST=your_raffle_list_id
SENDY_CUSTOMER_LIST=your_customer_list_id
SENDY_API_KEY=your_sendy_api_key

; Cloudflare Turnstile
CF_SECRET_KEY=your_cloudflare_turnstile_secret_key

; Google reCAPTCHA (legacy, unused at runtime)
GRC_SECRET_KEY=your_google_recaptcha_secret_key

; Debug (review-email.php, refill-email.php)
DEBUG_ORDER_ID=
DEBUG_EMAIL=
